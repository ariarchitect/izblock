# Keep template dirs and package manifest in git
!artifacts/.gitkeep
!build/autocad/template/IzAutoCADPlugin.bundle/PackageContents.xml
!build/autocad/template/IzAutoCADPlugin.bundle/Contents/2023/.gitkeep
!build/autocad/template/IzAutoCADPlugin.bundle/Contents/2024/.gitkeep
